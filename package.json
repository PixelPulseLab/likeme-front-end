{
  "name": "likeme-front-end",
  "version": "1.11.0",
  "description": "React Native app for health and wellness",
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "build:android:local": "./build-android-local.sh",
    "run:emulator:ios": "bash scripts/ios-simulator.sh",
    "ios:xcode:build:debug": "cd ios && xcodebuild -workspace LikeMe.xcworkspace -scheme LikeMe -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' -derivedDataPath build/DerivedData clean build",
    "run:emulator:android": "./start-emulator.sh",
    "start": "npx expo start --dev-client --reset-cache --clear",
    "start:ios": "open -a Simulator && npm run start",
    "start:clear": "bash scripts/clear-expo-metro-cache.sh && npm run start",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:update": "jest --updateSnapshot",
    "test:e2e": "~/.maestro/bin/maestro test maestro/",
    "test:e2e:welcome": "~/.maestro/bin/maestro test maestro/welcome-screen.yaml",
    "test:e2e:objectives": "~/.maestro/bin/maestro test maestro/personal-objectives.yaml",
    "test:e2e:onboarding": "~/.maestro/bin/maestro test maestro/onboarding-flow.yaml",
    "test:e2e:journey": "~/.maestro/bin/maestro test maestro/complete-user-journey.yaml",
    "test:e2e:expo-go": "./maestro/run-expo-go-tests.sh",
    "export:screenshots": "~/.maestro/bin/maestro test maestro/export-screenshots.yaml --test-output-dir=.maestro/screenshots",
    "export:screenshots:app": "~/.maestro/bin/maestro test maestro/export-screenshots-app.yaml --test-output-dir=.maestro/screenshots",
    "build": "npx tsc --noEmit && npm run lint",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "doctor": "npx expo-doctor",
    "version:sync": "node scripts/sync-app-version.cjs",
    "version:check": "node scripts/sync-app-version.cjs --check",
    "assert:ios-apple-signin": "node scripts/assert-ios-apple-signin.cjs",
    "assert:ios-share-links": "node scripts/assert-ios-share-associated-domains.cjs",
    "native:prebuild": "npm run version:sync && expo prebuild",
    "native:prebuild:clean": "npm run version:sync && expo prebuild --clean",
    "build:android": "env-cmd -f .env.production bash -c 'export JAVA_HOME=$(/usr/libexec/java_home -v 17) && cd android && ./gradlew :app:bundleRelease'",
    "android:keystore:verify": "bash scripts/android-keystore-verify-local.sh",
    "android:keystore:test-b64": "bash scripts/android-keystore-test-github-b64.sh",
    "build:android:gradle": "EXCLUDE_EXPO_DEV_CLIENT=1 npx expo prebuild --platform android && cd android && ./gradlew assembleRelease && cd ..",
    "build:android:apk": "./build-android-apk.sh",
    "ios:pod-install:store": "cd ios && EXCLUDE_EXPO_DEV_CLIENT=1 pod install",
    "ios:xcode:build:release": "cd ios && xcodebuild -workspace LikeMe.xcworkspace -scheme LikeMe -configuration Release -destination 'generic/platform=iOS' -sdk iphoneos -allowProvisioningUpdates build",
    "ios:xcode:build:production": "npm run ios:pod-install:store && cd ios && xcodebuild -workspace LikeMe.xcworkspace -scheme LikeMe -configuration Production -destination 'generic/platform=iOS' -sdk iphoneos -allowProvisioningUpdates build",
    "ios:xcode:archive:release": "cd ios && xcodebuild -workspace LikeMe.xcworkspace -scheme LikeMe -configuration Release -destination 'generic/platform=iOS' -archivePath \"$PWD/build/LikeMe.xcarchive\" -allowProvisioningUpdates archive",
    "ios:xcode:archive:production": "cd ios && xcodebuild -workspace LikeMe.xcworkspace -scheme LikeMe -configuration Production -destination 'generic/platform=iOS' -archivePath \"$PWD/build/LikeMe.xcarchive\" -allowProvisioningUpdates archive",
    "ios:xcode:export": "cd ios && xcodebuild -exportArchive -allowProvisioningUpdates -archivePath \"$PWD/build/LikeMe.xcarchive\" -exportPath \"$PWD/build/export\" -exportOptionsPlist \"$PWD/ExportOptions-AppStore.plist\"",
    "ios:xcode:export-adhoc": "bash -c 'IOS_ADHOC_PROVISIONING_PROFILE=\"Devices Ad Hoc for Dev\" IOS_ADHOC_PROVISIONING_FILE=\"${IOS_ADHOC_PROVISIONING_FILE:-$HOME/Downloads/Devices_Ad_Hoc_for_Dev.mobileprovision}\" exec bash scripts/ios-export-adhoc.sh'",
    "ios:signing:diagnose": "bash scripts/ios-signing-diagnose.sh",
    "ios:appstore:validate": "bash scripts/ios-appstore-altool.sh validate",
    "ios:appstore:upload": "bash scripts/ios-appstore-altool.sh upload",
    "ios:appstore:pipeline": "npm run ios:xcode:build:production && npm run ios:xcode:archive:production && npm run ios:xcode:export && npm run ios:appstore:validate && npm run ios:appstore:upload",
    "ios:archive:export": "bash scripts/archive-and-export-ipa.sh",
    "run:apk": "./run-apk.sh",
    "install:apk": "./install-and-run-apk.sh",
    "clean": "rm -rf node_modules/.cache .expo dist android/build ios/build",
    "clean:all": "rm -rf node_modules/.cache .expo dist android/build ios/build android/app/build ios/Pods ios/Podfile.lock",
    "clean:project": "./scripts/clean-project.sh",
    "clean:android": "cd android && ./gradlew clean && cd ..",
    "clean:ios": "cd ios && rm -rf Pods Podfile.lock build && pod install && cd ..",
    "revopush:release:ios": "bash scripts/revopush-release.sh ios",
    "revopush:release:android": "bash scripts/revopush-release.sh android",
    "revopush:release:all": "bash scripts/revopush-release.sh ios Production && bash scripts/revopush-release.sh android Production",
    "postinstall": "node scripts/ensure-onboarding-debug.cjs && node scripts/patch-slider-podspec.js && node scripts/patch-rn-third-party-components-provider.js && node scripts/patch-expo-js-logger.js && if [ -d ios ] && [ -f ios/Podfile ] && [ \"$SKIP_IOS_POD_INSTALL\" != \"true\" ]; then cd ios && pod install && cd ..; fi",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "dependencies": {
    "@expo-google-fonts/bricolage-grotesque": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-native-firebase/analytics": "^23.8.5",
    "@react-native-firebase/app": "^23.8.5",
    "@react-native-firebase/messaging": "^23.8.5",
    "@react-native-firebase/remote-config": "^23.8.5",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@revopush/expo-code-push-plugin": "^1.1.0",
    "@revopush/react-native-code-push": "^2.5.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-splash-screen": "~31.0.13",
    "i18next": "^25.8.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.3",
    "react-native": "0.81.5",
    "react-native-auth0": "^5.4.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.11.1",
    "react-native-play-install-referrer": "^1.1.9",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.1",
    "react-native-vector-icons": "^10.0.2",
    "react-native-video": "^6.19.1",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "^0.81.0",
    "@react-native/eslint-config": "^0.81.0",
    "@react-native/metro-config": "^0.81.0",
    "@revopush/code-push-cli": "^0.0.12",
    "@testing-library/react-native": "^13.3.3",
    "@tsconfig/react-native": "^3.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "~19.1.0",
    "babel-jest": "^29.2.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "dotenv": "^17.2.3",
    "env-cmd": "^11.0.0",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "~9.0.0",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "lint-staged": "^16.2.7",
    "prettier": "^2.4.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "react-native",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-vector-icons|react-native-video|expo|@expo|expo-auth-session|@react-navigation|@react-native-community|@revopush)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@/assets/(.*)$": "<rootDir>/assets/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "lint-staged": {
    "app.version.json": [
      "node scripts/sync-app-version.cjs",
      "node scripts/stage-app-version-sync-outputs.cjs"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.{spec,test}.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
