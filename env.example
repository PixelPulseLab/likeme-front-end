# Auth0 Configuration
EXPO_PUBLIC_AUTH0_DOMAIN=your-auth0-domain.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your-auth0-client-id
EXPO_PUBLIC_AUTH0_AUDIENCE=your-api-identifier

# Backend Configuration
# Production: https://likeme-back-end-one.vercel.app
EXPO_PUBLIC_BACKEND_URL=https://likeme-back-end-one.vercel.app/

# URLs das lojas (fallback quando GET /api/app/release-policy não envia storeUrlIos / Android)
# EXPO_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/br/app/like-me/id6757706434
# EXPO_PUBLIC_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.likeme.app

# Links compartilháveis (Universal/App Links)
EXPO_PUBLIC_SHARE_BASE_URL=https://app.likeme.global

# Auth Settings (URLs fixas = configure no Auth0 uma vez só, sem atualizar a cada deploy)
EXPO_PUBLIC_USE_AUTH_PROXY=true
EXPO_PUBLIC_AUTH_SCHEME=likeme
EXPO_PUBLIC_AUTH_PROXY_URL=https://auth.expo.dev/@pixelpulselab/likeme-front-end
EXPO_PUBLIC_AUTH_PROXY_PROJECT=@pixelpulselab/likeme-front-end
EXPO_PUBLIC_AUTH_REDIRECT_PATH=auth
# No Auth0 (Allowed Callback URLs e Allowed Logout URLs), use apenas:
#   https://auth.expo.dev/@pixelpulselab/likeme-front-end
#   likeme://auth

# TestFlight / App Store Connect (build local / altool)
# E-mail da conta Apple Developer (scripts ios:appstore:*)
APPLE_ID=seu-apple-id@email.com

ANDROID_KEYSTORE_STORE_PASSWORD=senha-google-console
ANDROID_KEYSTORE_KEY_PASSWORD=senha-google-console
ANDROID_KEYSTORE_KEY_ALIAS=likeme-key-alias
ANDROID_KEYSTORE_STORE_FILE=likeme-release.keystore