#!/bin/sh
echo "📋 Verificando versão e CHANGELOG..."
npm run version:check
if [ $? -ne 0 ]; then
  echo "❌ Push bloqueado: rode npm run version:sync e inclua os arquivos gerados no commit."
  exit 1
fi

. "$(dirname "$0")/../scripts/pre-push-release-tests.sh"

echo "🔨 Validando build (typecheck + lint)..."
npm run build
if [ $? -ne 0 ]; then
  echo "❌ Push bloqueado: build falhou. Corrija os erros antes de fazer push."
  exit 1
fi
echo "✅ Versão, testes e build OK. Prosseguindo com o push."
